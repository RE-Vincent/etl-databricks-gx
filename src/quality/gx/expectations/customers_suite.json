{
  "expectation_suite_name": "customer_suite",
  "ge_cloud_id": null,
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_ordered_list",
      "kwargs": {
        "column_list": [
          "customer_id",
          "name",
          "age",
          "country",
          "phone_number",
          "signup_date"
        ]
      },
      "meta": {
        "dimension": "schema",
        "notes": "Verifica que el contrato de datos no haya cambiado."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {
        "column": "customer_id"
      },
      "meta": {
        "dimension": "uniqueness",
        "severity": "critical",
        "notes": "Detecta los 5 registros duplicados por el concat."
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "phone_number"
      },
      "meta": {
        "dimension": "missingness",
        "notes": "Captura el valor nulo inyectado en la fila 100."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "age",
        "min_value": 18,
        "max_value": 80
      },
      "meta": {
        "dimension": "accuracy",
        "notes": "Detecta edades fuera de rango (10 y 100 años)."
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "phone_number",
        "regex": "^\\+51\\d{9}$"
      },
      "meta": {
        "dimension": "validity",
        "notes": "Valida el formato de teléfono peruano (+51 + 9 dígitos)."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "signup_date",
        "max_value": "2026-04-14"
      },
      "meta": {
        "dimension": "consistency",
        "notes": "Captura fechas futuras (error inyectado 2027-01-01)."
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "country",
        "value_set": [
          "PE",
          "CL",
          "MX"
        ]
      },
      "meta": {
        "dimension": "integrity",
        "notes": "Asegura que el país esté en la lista de países permitidos."
      }
    },
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "max_value": 110,
        "min_value": 95
      },
      "meta": {
        "dimension": "volume",
        "notes": "Controla que el volumen de carga sea el esperado."
      }
    }
  ],
  "meta": {
    "citations": [
      {
        "citation_date": "2026-04-14T12:00:00Z",
        "comment": "Suite creada para validación de capa Bronze a Silver de Clientes."
      }
    ],
    "great_expectations_version": "0.18.x"
  }
}